// ARIA - AI Executive Assistant
// Prisma Schema — SQLite (dev), PostgreSQL (prod)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── AUTH ────────────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  image         String?
  emailVerified DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts         Account[]
  sessions         Session[]
  integrations     Integration[]
  emails           Email[]
  threads          Thread[]
  tasks            Task[]
  analyses         AIAnalysis[]
  calendarEvents   CalendarEvent[]
  briefings        Briefing[]
  settings         UserSettings?
  vipContacts      VipContact[]
  emailTemplates   EmailTemplate[]
  followupReminders FollowupReminder[]
  scheduledEmails  ScheduledEmail[]
  extensionTokens  ExtensionToken[]
  outboxEmails     OutboxEmail[]
  emailSignatures  EmailSignature[]
  emailRules       EmailRule[]
  notifications    Notification[]
  webhooks         Webhook[]
  knowledgeItems   KnowledgeItem[]
  contactNotes     ContactNote[]
  draftEmails      DraftEmail[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ─── INTEGRATIONS ────────────────────────────────────────────────────

model Integration {
  id           String   @id @default(cuid())
  userId       String
  provider     String   // GMAIL | OUTLOOK
  email        String
  accessToken  String
  refreshToken String?
  expiresAt    DateTime?
  scope        String?
  isActive     Boolean  @default(true)
  lastSyncAt   DateTime?
  syncCursor   String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, provider, email])
  @@map("integrations")
}

// ─── EMAILS ──────────────────────────────────────────────────────────

model Thread {
  id           String   @id @default(cuid())
  userId       String
  provider     String
  externalId   String
  subject      String
  participants String   // JSON array
  messageCount Int      @default(0)
  hasUnread    Boolean  @default(false)
  lastEmailAt  DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  emails       Email[]

  @@unique([userId, provider, externalId])
  @@map("threads")
}

model Email {
  id               String    @id @default(cuid())
  userId           String
  threadId         String?
  provider         String
  externalId       String
  subject          String
  bodyText         String
  bodyHtml         String?
  fromEmail        String
  fromName         String?
  toEmails         String    // JSON array
  ccEmails         String    @default("[]")
  labels           String    @default("[]") // JSON array
  isRead           Boolean   @default(false)
  isStarred        Boolean   @default(false)
  isSnoozed        Boolean   @default(false)
  snoozeUntil      DateTime?
  snoozedUntil     DateTime?
  followUpAt       DateTime?
  readReceiptToken String?
  openedAt         DateTime?
  openCount        Int       @default(0)
  hasAttachments   Boolean   @default(false)
  receivedAt       DateTime
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  user              User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  thread            Thread?            @relation(fields: [threadId], references: [id])
  analysis          AIAnalysis?
  tasks             Task[]
  followupReminders FollowupReminder[]

  @@unique([userId, provider, externalId])
  @@index([userId, receivedAt])
  @@index([userId, isRead])
  @@map("emails")
}

// ─── AI ANALYSIS ─────────────────────────────────────────────────────

model AIAnalysis {
  id                  String   @id @default(cuid())
  emailId             String   @unique
  userId              String
  priority            String   // CRITICAL|HIGH|MEDIUM|LOW
  category            String   // MEETING|TASK|CRITICAL|INFO|SPAM|NEWSLETTER|INVOICE
  intent              String
  summary             String
  deadline            DateTime?
  deadlineText        String?
  amount              String?
  sentiment           String   // POSITIVE|NEUTRAL|NEGATIVE|URGENT
  urgencyScore        Int
  suggestedAction     String
  meetingDetected     Boolean  @default(false)
  meetingTime         String?
  meetingParticipants String   @default("[]") // JSON array
  taskExtracted       Boolean  @default(false)
  taskText            String?
  confidenceScore     Float
  replyShort          String?
  replyProfessional   String?
  replyFriendly       String?
  tokensUsed          Int?
  processingMs        Int?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  email               Email    @relation(fields: [emailId], references: [id], onDelete: Cascade)
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, priority])
  @@map("ai_analyses")
}

// ─── TASKS ───────────────────────────────────────────────────────────

model Task {
  id          String   @id @default(cuid())
  userId      String
  emailId     String?
  title       String
  description String?
  dueDate     DateTime?
  priority    String   @default("MEDIUM")
  status      String   @default("TODO")
  source      String   @default("AI_GENERATED")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  email       Email?   @relation(fields: [emailId], references: [id])

  @@index([userId, status])
  @@index([userId, dueDate])
  @@map("tasks")
}

// ─── CALENDAR ────────────────────────────────────────────────────────

model CalendarEvent {
  id           String   @id @default(cuid())
  userId       String
  externalId   String?
  provider     String?
  title        String
  description  String?
  startTime    DateTime
  endTime      DateTime
  location     String?
  meetingUrl   String?
  participants String   @default("[]") // JSON array
  isConflict   Boolean  @default(false)
  ariaCreated  Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, startTime])
  @@map("calendar_events")
}

// ─── BRIEFINGS ───────────────────────────────────────────────────────

model Briefing {
  id           String   @id @default(cuid())
  userId       String
  date         DateTime
  content      String
  emailCount   Int
  criticalCount Int
  tasksCount   Int
  waitingCount Int
  tokensUsed   Int?
  createdAt    DateTime @default(now())

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@map("briefings")
}

// ─── VIP CONTACTS ────────────────────────────────────────────────────

model VipContact {
  id        String   @id @default(cuid())
  userId    String
  email     String
  name      String?
  reason    String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, email])
  @@map("vip_contacts")
}

// ─── EMAIL TEMPLATES ─────────────────────────────────────────────────────────

model EmailTemplate {
  id        String   @id @default(cuid())
  userId    String
  name      String
  subject   String   @default("")
  body      String
  variables String   @default("[]")
  category  String?
  useCount  Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("email_templates")
}

// ─── FOLLOW-UP REMINDERS ─────────────────────────────────────────────────────

model FollowupReminder {
  id        String   @id @default(cuid())
  userId    String
  emailId   String
  dueAt     DateTime
  note      String?
  isDone    Boolean  @default(false)
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  email     Email    @relation(fields: [emailId], references: [id], onDelete: Cascade)

  @@map("followup_reminders")
}

// ─── SCHEDULED EMAILS ────────────────────────────────────────────────────────

model ScheduledEmail {
  id          String    @id @default(cuid())
  userId      String
  toEmail     String
  subject     String
  body        String
  scheduledAt DateTime
  sentAt      DateTime?
  status      String    @default("PENDING")
  replyToId   String?
  createdAt   DateTime  @default(now())

  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("scheduled_emails")
}

// ─── EXTENSION TOKENS ────────────────────────────────────────────────

model ExtensionToken {
  id         String    @id @default(cuid())
  userId     String
  token      String    @unique
  label      String    @default("Chrome Extension")
  lastUsedAt DateTime?
  createdAt  DateTime  @default(now())

  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("extension_tokens")
}

// ─── OUTBOX / SCHEDULING ─────────────────────────────────────────────────────

model OutboxEmail {
  id          String    @id @default(cuid())
  userId      String
  to          String
  subject     String
  body        String
  scheduledAt DateTime
  sentAt      DateTime?
  createdAt   DateTime  @default(now())
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("outbox_emails")
}

// ─── EMAIL SIGNATURES ────────────────────────────────────────────────────────

model EmailSignature {
  id        String   @id @default(cuid())
  userId    String
  name      String
  content   String
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("email_signatures")
}

// ─── EMAIL RULES ─────────────────────────────────────────────────────────────

model EmailRule {
  id               String    @id @default(cuid())
  userId           String
  name             String
  enabled          Boolean   @default(true)
  triggerField     String    // from | subject | body | category | priority | sentiment | hasAttachment
  triggerOperator  String    // contains | equals | startsWith | endsWith | is
  triggerValue     String
  action           String    // archive | markRead | createTask | snooze | label | forward | notifyWebhook | autoReply | setVip
  actionValue      String?
  triggerCount     Int       @default(0)
  lastTriggeredAt  DateTime?
  aiGenerated      Boolean   @default(false)
  createdAt        DateTime  @default(now())
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("email_rules")
}

// ─── NOTIFICATIONS ────────────────────────────────────────────────────────────

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String   // followup | snooze | rule | system
  title     String
  body      String
  emailId   String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

// ─── SETTINGS ────────────────────────────────────────────────────────

model UserSettings {
  id                   String   @id @default(cuid())
  userId               String   @unique
  aiModel              String   @default("claude-sonnet-4-6")
  language             String   @default("bs")
  briefingTime         String   @default("07:45")
  syncInterval         Int      @default(5)
  autoAnalyze          Boolean  @default(true)
  autoCreateTasks      Boolean  @default(true)
  notificationsEnabled Boolean  @default(true)
  timezone             String   @default("Europe/Sarajevo")
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_settings")
}

// ─── KNOWLEDGE BASE ──────────────────────────────────────────────────────────

model KnowledgeItem {
  id          String   @id @default(cuid())
  userId      String
  title       String
  content     String
  source      String   @default("MANUAL") // MANUAL | NOTE | PASTE
  tags        String   @default("[]")     // JSON array of tag strings
  useCount    Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("knowledge_items")
}

// ─── CONTACT NOTES ───────────────────────────────────────────────────────────

model ContactNote {
  id        String   @id @default(cuid())
  userId    String
  email     String
  note      String
  aiSummary String?
  source    String   @default("MANUAL") // MANUAL | BRAIN_DUMP | AI_SUMMARY
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, email])
  @@map("contact_notes")
}

// ─── DRAFT EMAIL QUEUE ───────────────────────────────────────────────────────

model DraftEmail {
  id           String    @id @default(cuid())
  userId       String
  toEmail      String
  subject      String
  body         String
  status       String    @default("PENDING")  // PENDING | APPROVED | REJECTED | SENT
  source       String    @default("RULE")     // RULE | WEBHOOK | BRAIN_DUMP
  triggerType  String?   // invoice_paid | lead_received | autoReply | etc.
  triggerData  String?   // JSON blob of original payload / email context
  ruleId       String?   // Which EmailRule created this
  sourceEmailId String?  // The email that triggered the autoReply rule
  sentAt       DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@map("draft_emails")
}

// ─── WEBHOOKS ────────────────────────────────────────────────────────────────

model Webhook {
  id        String   @id @default(cuid())
  userId    String
  name      String
  url       String
  event     String   // INVOICE_RECEIVED | LEAD_RECEIVED
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("webhooks")
}
